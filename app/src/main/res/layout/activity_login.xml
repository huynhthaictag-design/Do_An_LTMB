<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F8">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:layout_gravity="center">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="#0056B2"
            android:contentDescription="@string/todo"
            android:padding="14dp"
            android:src="@drawable/ic_launcher_foreground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_back"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#000"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/logoIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_in_to_your_account"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email -->
        <EditText
            android:id="@+id/emailInput"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:autofillHints=""
            android:hint="@string/email_or_username"
            android:background="@drawable/input_background"
            android:padding="16dp"
            android:layout_marginTop="30dp"
            android:inputType="textEmailAddress"
            app:layout_constraintTop_toBottomOf="@id/subtitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Password -->
        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:autofillHints=""
            android:hint="@string/password"
            android:background="@drawable/input_background"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:inputType="textPassword"
            app:layout_constraintTop_toBottomOf="@id/emailInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Remember -->
        <CheckBox
            android:id="@+id/rememberCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/keep_me_signed_in"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/passwordInput"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Forgot password -->
        <TextView
            android:id="@+id/forgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/forgot_password"
            android:textColor="#0056B2"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/rememberCheck"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Login Button -->
        <Button
            android:id="@+id/loginButton"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="@string/sign_in"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0056B2"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/rememberCheck"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider -->
        <TextView
            android:id="@+id/orText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or_continue_with"
            android:textColor="#888888"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/loginButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Google -->
        <Button
            android:id="@+id/googleLogin"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/google"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000"
            app:layout_constraintTop_toBottomOf="@id/orText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/facebookLogin" />

        <!-- Facebook -->
        <Button
            android:id="@+id/facebookLogin"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/facebook"
            android:layout_marginTop="20dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#1877F2"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/orText"
            app:layout_constraintStart_toEndOf="@id/googleLogin"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Register -->
        <TextView
            android:id="@+id/registerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/don_t_have_an_account_create_account"
            android:textColor="#555"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/googleLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>