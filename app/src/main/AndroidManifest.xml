<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DoAnLTMB">

        <activity
            android:name=".activity.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.RegisterActivity"
            android:exported="false"/>

        <activity
            android:name=".activity.user.MainActivity"
            android:windowSoftInputMode="adjustPan"
            android:exported="false"/>

        <activity
            android:name=".activity.user.ProfileActivity"
            android:exported="false"/>

        <activity
            android:name=".activity.admin.AddProductActivity"
            android:exported="false"/>
        <activity
            android:name=".activity.user.ProductDetailActivity"
            android:exported="false"/>
        <activity
            android:name=".activity.user.EditProfileActivity"
            android:exported="false"/>

    </application>
</manifest>